--- !u!114 &7734780646959182002
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 4223719963560215399}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 70fcbda48c492f64b8ffce2ef968c2f2, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::discoDialogue
  dialogueIndex: 0
  subIndex: 0
  NM: {fileID: 0}
  Dialogue: {fileID: 803801570827974913}
  DialogBackUI: {fileID: 2016424619869944546}
  platmanscript: {fileID: 0}
  EndL: {fileID: 0}
  KillZ: {fileID: 0}
  NPCDissappear: {fileID: 0}
  DilogueDissappear: {fileID: 2016424619869944546}
  firstConvo:
  - Hey kid, ready to tango?
  - The goal is to jump on the right platforms to get to the end
  - of the dance floor! Whenever your ready talk to me again
  - and we will get this party started!
  secondConvo:
  - Lets do this!
  thirdConvo:
  - Nice Dancing! What were you looking for again?
  - The Disc Pieces?.. I think I have some in my studio but...
  - Unfortunately a vengeful fan screwed up my setup.
  - If you can fix it, you can have my disc pieces!
  fourthConvo:
  - What are you waiting for?
  fifthConvo:
  - "G\u0320\u033F\u0353\u0318\u034C\u0353\u0367\u0342\u031B\u0302\u036F\u0336\u0358\u033A\u0366\u0303\u0349\u0328\u0305\u0327\u036E\u0301\u0358\u0342\u033F\u0307\u0324\u032E\u0320\u0310\u0306\u036Fe\u030E\u030F\u032D\u0305\u0346\u0346\u034B\u0328\u033C\u0328t\u0361\u0335\u0303\u034C\u035B\u0315\u0345\u030A\u0367\u032B\u0301\u0313\u035F\u0355\u0334\u0368\u0318\u0338\u030B\u0354\u0309\u0302\u0318\u034D
    r\u034D\u0365\u0336\u0318\u035E\u031E\u0330\u030E\u0333\u036E\u0368\u0315\u0300_\u0301\u0350\u031C\u0348\u0331_\u0309\u031Fe\u030C\u0357\u034C\u0356\u0349\u033E\u0327a\u0327\u034C\u0317d\u0337\u0338\u0335\u0357\u0316\u0339\u030B\u0352\u0313\u0368\u0318\u031D\u0302\u031C\u0361\u0315\u0365\u035A\u0346\u0353\u0319\u034E\u030B\u0346\u031C\u0310y\u034E\u0306\u0362\u0351\u0365\u0326\u0332\u0368\u0306\u0304\u0319\u0349\u031D\u0312\u0357\u0317\u0314\u0302\u0308\u0301\u0327\u0332
    t\u0307\u0369\u0311\u0363\u0301\u0355\u0351\u036B\u0308\u031B\u031D\u0318\u032D\u0312\u0321\u0322\u0336\u030F\u0323\u0331\u0366\u0318\u0362\u0351\u0300\u036C\u0350\u0300\u0310\u030E\u0301\u0320\u033F\u0334\u030A\u0347\u0352\u0301o\u0307\u0316\u0337\u030F\u0367\u0348\u0332\u0313\u034A\u033D\u0313\u034D\u034D\u036E\u0348\u032E\u0358\u0337\u0359\u0317\u033B\u033C\u0314
    g\u0353\u0362\u036F\u035F\u0318\u030C\u032E\u033C\u0350\u0339\u0342\u0301\u032F\u0352\u030Ce\u0357\u032A\u032F\u033C\u033E\u0302\u033D\u031A\u036F\u0316\u0314\u031E\u0318\u0328\u0321\u034A\u0302\u0357\u0306\u031E\u0347\u0351\u0357\u0369\u031F\u032D\u0368\u035C\u0369\u034B\u031C\u032C\u0309\u0307\u0368\u034Bt\u0330\u0354\u0342\u0319\u0342\u0308\u0359\u0317\u0364\u0366\u035F\u034E\u0349\u0365\u0327\u0335\u0342\u036A\u0331\u034A\u0311\u031F\u034C\u032E_\u0363\u0313\u036C
    C\u0361\u031F\u035B\u0342\u0366\u032A\u030D\u033B\u034B\u034B\u036C\u0315\u0342\u036B\u034C\u036C\u0353\u0363\u036F\u0348\u0316R\u0351\u0350\u032F\u031B\u0301\u034B\u0332\u0356\u033A\u033C\u0360\u030C\u032F\u0316\u0349\u032F\u035A\u0346\u033D\u0335\u030C\u0329\u036F\u031E\u033F\u034E\u0332\u0363\u0364\u0303\u034C\u0350\u0308\u0301\u0308\u032C\u0365\u0317\u0362\u034B\u036A\u0301\u0347U\u0300\u0356\u0312\u0348\u0315S\u032B\u033A\u033B\u0306\u0317\u0363H\u030E\u036A\u0360\u0317\u033B\u0359\u032A\u0323\u034D\u0349\u0367\u031E\u034E\u032B\u036E\u0320\u0307\u0357\u035A\u0326\u0355\u032D\u0359\u0348\u031E\u030E\u0303\u0367\u0327\u033E\u0323\u0305\u0311\u0365\u0324\u0327\u0330\u0361\u0305\u035B\u0313\u0310E\u0367\u0339\u031A\u0365\u031B\u033B\u035E_\u0353\u0300\u033C\u0364\u0336D\u0348\u033D\u0324\u0306\u0351\u0300\u0317\u031B\u0315\u0359\u031B\u0336\u0302\u031E\u034C\u0307\u036E\u0347\u030F\u0322"
